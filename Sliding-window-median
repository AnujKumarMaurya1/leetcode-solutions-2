import heapq
from collections import defaultdict

class Solution:
    def medianSlidingWindow(self, nums: list[int], k: int) -> list[float]:
        small = []
        large = []
        lazy_delete = defaultdict(int)
        
        small_size = 0
        large_size = 0
        
        def add(num):
            nonlocal small_size, large_size
            if not small or num <= -small[0]:
                heapq.heappush(small, -num)
                small_size += 1
            else:
                heapq.heappush(large, num)
                large_size += 1
            balance()
            
        def remove(num):
            nonlocal small_size, large_size
            lazy_delete[num] += 1
            if num <= -small[0]:
                small_size -= 1
            else:
                large_size -= 1
            balance()
            
        def balance():
            nonlocal small_size, large_size
            if small_size > large_size + 1:
                heapq.heappush(large, -heapq.heappop(small))
                small_size -= 1
                large_size += 1
                prune()
            elif small_size < large_size:
                heapq.heappush(small, -heapq.heappop(large))
                large_size -= 1
                small_size += 1
                prune()
                
        def prune():
            while small and lazy_delete[-small[0]] > 0:
                lazy_delete[-small[0]] -= 1
                heapq.heappop(small)
            while large and lazy_delete[large[0]] > 0:
                lazy_delete[large[0]] -= 1
                heapq.heappop(large)
                
        def get_median():
            if k % 2 == 1:
                return float(-small[0])
            else:
                return (-small[0] + large[0]) / 2.0

        for i in range(k):
            add(nums[i])
            
        result = [get_median()]
        
        for i in range(k, len(nums)):
            add(nums[i])
            remove(nums[i - k])
            prune()
            result.append(get_median())
            
        return result
