class Solution:
    def circularArrayLoop(self, nums: list[int]) -> bool:
        n = len(nums)
        
        def get_next(i):
            return ((i + nums[i]) % n + n) % n
            
        for i in range(n):
            if nums[i] == 0:
                continue
                
            slow = i
            fast = i
            
            while nums[get_next(slow)] * nums[i] > 0 and \
                  nums[get_next(fast)] * nums[i] > 0 and \
                  nums[get_next(get_next(fast))] * nums[i] > 0:
                  
                slow = get_next(slow)
                fast = get_next(get_next(fast))
                
                if slow == fast:
                    if slow == get_next(slow):
                        break
                    return True
            
            curr = i
            val = nums[i]
            while nums[curr] * val > 0:
                nxt = get_next(curr)
                nums[curr] = 0
                curr = nxt
                
        return False
