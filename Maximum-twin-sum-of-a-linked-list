class Solution:
    def pairSum(self, head: Optional[ListNode]) -> int:
        slow = head
        fast = head
        
        while fast and fast.next:
            slow = slow.next
            fast = fast.next.next
            
        prev = None
        curr = slow
        while curr:
            nxt = curr.next
            curr.next = prev
            prev = curr
            curr = nxt
            
        first = head
        second = prev
        max_sum = 0
        
        while second:
            current_sum = first.val + second.val
            if current_sum > max_sum:
                max_sum = current_sum
            first = first.next
            second = second.next
            
        return max_sum
